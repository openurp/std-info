[#ftl]
<table class="infoTable">
  <tr>
    <td align="right">电子邮件：</td>
    <td><input type="text" style="width:120px" name="contact.mail" value="${Parameters["contact.mail"]!}"/></td>
    <td align="right">联系电话：</td>
    <td><input type="text" style="width:120px" name="contact.phone" value="${Parameters["contact.phone"]!}"/></td>
    <td align="right">移动电话：</td>
    <td><input type="text" style="width:120px" name="contact.mobile" value="${Parameters["contact.mobile"]!}"/></td>
    <td align="right">通讯地址：</td>
    <td><input type="text" style="width:120px" name="contact.address" value="${Parameters["contact.address"]!}"/></td>
  </tr>
</table>
